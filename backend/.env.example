APP_ENV=dev
APP_NAME=guroo-api
APP_HOST=0.0.0.0
APP_PORT=8001
APP_DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/guroo

JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASSWORD=app_password
SMTP_FROM=example@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Legacy Django-compatible names (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=example@gmail.com
EMAIL_HOST_PASSWORD=app_password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=example@gmail.com

MEDIA_ROOT=./media

# Optional: absolute or relative path to the Excel template for analytics export
REPORT_TEMPLATE_PATH=..\Отчетный_материал_по_ТЬЮТОРАМ_2023_2025_УГ.xlsx
